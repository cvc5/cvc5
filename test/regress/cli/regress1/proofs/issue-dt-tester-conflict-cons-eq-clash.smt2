; COMMAND-LINE: --sat-solver=cadical
; EXPECT: unsat
; Tests that the proof for a datatypes tester merge conflict (is-C1(x) and
; is-C2(x) for distinct constructors C1, C2) is reconstructed via the
; (proof-checkable) DT_CONS_EQ_CLASH rule, rather than leaving an unelaborated
; MACRO_DT_CONS_EQ theory rewrite step that yields an incomplete proof.
(set-logic ALL)
(declare-const x Bool)
(declare-sort SP 0)
(declare-fun I (Int) SP)
(declare-sort ST 0)
(declare-sort SD 0)
(declare-datatypes ((SeB 0) (Ss 0) (Sre 0) (Se 0) (St 0) (SrB 0) (Sb 0) (SbB 0) (Sv 0) (Sp 0) (Sm 0) (Sli 0) (Su 0) (Sl 0)) (((or)) ((e)) ((re (e SP)) (e (l SP))) ((or)) ((u)) ((u)) ((b!)) ((vB)) ((v)) ((p)) ((m)) ((b!)) ((u)) ((u (l SP) (p SP)))))
(declare-fun c (Sre) SP)
(declare-fun l (SbB) SP)
(declare-fun t (Sl) SP)
(declare-fun u (Sl) SP)
(declare-fun o (Sre) SP)
(declare-fun %P (SP) Sre)
(declare-fun o (SbB) SP)
(declare-fun P (SP) SbB)
(declare-fun o (Sv) SP)
(declare-fun o (Sl) SP)
(declare-fun % (SP) Sl)
(declare-fun b (SD ST SD ST SD ST SD ST SD ST SD ST SD ST SP) Sv)
(declare-fun l (SD ST SD ST SD ST SD ST SD ST SD ST SD ST SP) Sv)
(declare-fun l (SD ST SD ST SD ST SD ST SP SP SP) Sre)
(assert (or (forall ((& SD) (K ST) (&. SD) (I& ST) (L& SD) (L ST) (V& SD) (V ST) (E& SD) (s SP)) (= (l V& V & K &. I& L& L V& V V& V E& V s) (b V& V & K &. I& L& L V& V V& V E& V (l (P s)))))))
(assert (forall ((P SD) (M ST) (& SD) (K ST) (L& SD) (L ST) (D SD) (V& SD) (V ST) (E& SD) (E ST) (s SP) (k SP) (i Int) (r Sre)) (ite (and ((_ is re) (%P (t (% (o (u (o r) (o (l P M D K L& L E& E (o (b V& V P M D K L& L V& V V& V E& V s)) k (I i)))))))))) (= (c (%P (u (% (u (u (o r) (o (l P V V& V V& V V& V s (I 1) (o (b V& V V& V V& V V& V V& V V& V V& V s)))))))))) (c (%P (u (% (o (u (o r) (o (l & M D K L& L E& E (o (b V& V & M D K L& L V& V V& V E& V s)) k (I i)))))))))) x)))
(declare-const & SD)
(declare-const K ST)
(declare-const &. SD)
(declare-const I& ST)
(declare-const L& SD)
(declare-const L ST)
(declare-const V& SD)
(declare-const V ST)
(declare-const E& SD)
(declare-const E ST)
(declare-const r Sre)
(declare-const s SbB)
(declare-const k SP)
(declare-const i Int)
(assert (not (ite (and ((_ is re) (%P (t (% (o (u (o r) (o (l & K &. I& L& L E& E (o (l V& V & K &. I& L& L V& V V& V E& V (o s))) k (I i)))))))))) (= (c (%P (u (% (o (u (o r) (o (l & K &. I& L& L E& E (o (l V& V V& K &. I& L& L V& V V& V E& V (o s))) k (I i))))))))) (c (%P (u (% (o (u (o r) (o (l V& K &. I& L& L E& E (o (l V& V V& V V& V V& V V& V V& V V& V (o s))) k (I i)))))))))) x)))
(check-sat)
