; COMMAND-LINE: --sat-solver=cadical --check-proofs --check-proofs-complete
; EXPECT: unsat
; Tests that the proof for a datatypes tester merge conflict (is-C1(x) and
; is-C2(x) for distinct constructors C1, C2) is reconstructed via the
; (proof-checkable) DT_CONS_EQ_CLASH rule, rather than leaving an unelaborated
; MACRO_DT_CONS_EQ theory rewrite step that yields an incomplete proof.
(set-logic ALL)
(declare-const x Bool)
(declare-sort P 0)
(declare-fun I (Int) P)
(declare-sort T 0)
(declare-sort D 0)
(declare-datatypes ((e! 0) (s 0) (re 0) (e 0) (t 0) (!r 0) (b 0) (b! 0) (v 0) (p 0) (m 0) (li 0) (u 0) (l 0)) (((or)) ((e)) ((re (e P)) (e (l P))) ((or)) ((u)) ((u)) ((b!)) ((v)) ((v)) ((p)) ((m)) ((b!)) ((u)) ((u (l P) (p P)))))
(declare-fun c (re) P)
(declare-fun l (b!) P)
(declare-fun t (l) P)
(declare-fun u (l) P)
(declare-fun o (re) P)
(declare-fun %P (P) re)
(declare-fun o (b!) P)
(declare-fun P (P) b!)
(declare-fun o (v) P)
(declare-fun o (l) P)
(declare-fun % (P) l)
(declare-fun b (D T D T D T D T D T D T D T P) v)
(declare-fun l (D T D T D T D T D T D T D T P) v)
(declare-fun l (D T D T D T D T P P P) re)
(assert (or (forall ((& D) (K T) (&. D) (I& T) (L& D) (L T) (V& D) (V T) (E& D) (s P)) (= (l V& V & K &. I& L& L V& V V& V E& V s) (b V& V & K &. I& L& L V& V V& V E& V (l (P s)))))))
(assert (forall ((P D) (M T) (& D) (K T) (L& D) (L T) (D D) (V& D) (V T) (E& D) (E T) (s P) (k P) (i Int) (r re)) (ite (and ((_ is re) (%P (t (% (o (u (o r) (o (l P M D K L& L E& E (o (b V& V P M D K L& L V& V V& V E& V s)) k (I i)))))))))) (= (c (%P (u (% (u (u (o r) (o (l P V V& V V& V V& V s (I 1) (o (b V& V V& V V& V V& V V& V V& V V& V s)))))))))) (c (%P (u (% (o (u (o r) (o (l & M D K L& L E& E (o (b V& V & M D K L& L V& V V& V E& V s)) k (I i)))))))))) x)))
(declare-const & D)
(declare-const K T)
(declare-const &. D)
(declare-const I& T)
(declare-const L& D)
(declare-const L T)
(declare-const V& D)
(declare-const V T)
(declare-const E& D)
(declare-const E T)
(declare-const r re)
(declare-const s b!)
(declare-const k P)
(declare-const i Int)
(assert (not (ite (and ((_ is re) (%P (t (% (o (u (o r) (o (l & K &. I& L& L E& E (o (l V& V & K &. I& L& L V& V V& V E& V (o s))) k (I i)))))))))) (= (c (%P (u (% (o (u (o r) (o (l & K &. I& L& L E& E (o (l V& V V& K &. I& L& L V& V V& V E& V (o s))) k (I i))))))))) (c (%P (u (% (o (u (o r) (o (l V& K &. I& L& L E& E (o (l V& V V& V V& V V& V V& V V& V V& V (o s))) k (I i)))))))))) x)))
(check-sat)
