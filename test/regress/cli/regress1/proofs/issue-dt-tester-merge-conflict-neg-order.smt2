; COMMAND-LINE: --sat-solver=cadical --check-proofs --check-proofs-complete
; EXPECT: unsat
; Tests proof reconstruction of a datatypes tester merge conflict where the
; explanation lists the negated tester first, e.g. ~is-C(a) ^ is-C(b) ^ a=b.
; The positive tester must take the tester1 role so that DT_INST/CONTRA
; reconstruction applies, rather than falling back to a trust step.
(set-logic ALL)
(declare-sort P 0)
(declare-fun I (Int) P)
(declare-fun % (P) Int)
(declare-sort T 0)
(declare-const N T)
(declare-sort D 0)
(declare-const $ D)
(declare-fun pr (D T) D)
(declare-fun r (D T) T)
(declare-sort v 0)
(declare-sort s 0)
(declare-sort vs 0)
(declare-datatypes ((l 0) (u 0) (!s 0) (ib 0) (b 0) (sp 0) (m 0) (y 0) (b!s 0) (k 0) (pe 0) (i 0) (p 0) (o 0) (b! 0) (!sp 0) (e 0) (b!sp 0) (ib! 0) (ec 0) (spe 0) (. 0) (!spe 0) (c 0) (f 0) (ls 0) (t 0) (up 0) (n 0) (pl 0) (tu 0)) (((b!s (b!s vs))) ((b!sp)) ((!s)) ((f)) ((ib!)) ((!s)) ((f)) ((b!s)) ((y)) ((y)) ((!spe)) ((spe)) ((ec)) ((!spe)) ((y)) ((b!sp)) ((f)) ((spe)) ((f)) ((b!sp)) ((c)) ((b!s)) ((b!s)) ((e) (pe (ec vs)) (y (ib! Int))) ((ib)) ((y)) ((up)) ((pl)) ((y)) ((up)) ((y))))
(declare-fun l (l) P)
(declare-fun i (l) v)
(declare-fun li (l) s)
(declare-fun l (c) Int)
(declare-const Y T)
(declare-fun P (v) P)
(declare-fun P (s) P)
(declare-fun P (P) s)
(declare-fun P (l) P)
(declare-fun %P (P) l)
(declare-fun y (c) P)
(declare-fun Po (P) c)
(assert (forall ((x P)) (= x (P (P x)))))
(assert (forall ((x c)) (= x (Po (y x)))))
(declare-fun v (D T D T P) P)
(declare-fun v (D T D T P P) P)
(declare-fun vs (D T D T P P P) P)
(declare-fun vs (D T D T P P) P)
(declare-fun v (D T P P) Bool)
(declare-fun vs (D T P P) P)
(declare-fun l (D T P P P) Bool)
(declare-fun li (D T P) Bool)
(declare-fun l (D T P P) Int)
(assert (or (forall ((D D) (T T) (s P) (n P)) (= (l D T s n) (ite ((_ is e) (Po (v $ T $ Y (P (li (%P s))) n))) (% (v $ T $ T (P (i (%P s))) n)) (ite ((_ is pe) (Po (v $ T $ Y (P (li (%P s))) n))) (% (v $ T $ T (P (i (%P s))) n)) (l (Po (y (Po (v $ T $ Y (P (li (%P s))) n)))))))))))
(assert (or (forall ((D D) (s P)) (= (li D Y s) (forall ((d P)) (= (I (l D N s d)) (vs D Y (pr D Y) (r D Y) (l (%P s)) d)))))))
(assert (or (forall ((D D) (T T) (p P) (o P) (n P)) (= (l D T p o n) (and (= (i (%P o)) (i (%P p))) (= (l (%P o)) (l (%P p))) (v D Y o (P (i (%P p)))) ((_ is pe) (Po (v $ T $ Y (P (li (%P p))) n))) (= (li (%P o)) (P (vs $ T $ Y (P (P (vs $ T $ Y (P (li (%P p))) p))) n (y e)))))))))
(assert (forall ((& D) (V T) (m P) (k P) (a P)) (= a (v & V & Y (vs & V & Y m k a) k))))
(assert (forall ((& D) (V T) (m P) (k P) (e P) (a P)) (or (not (v & V (v & V & Y m) k)) (= (v & V & Y m k) (v & V & Y (vs & V & Y m e a) k)))))
(assert (forall ((& D) (V T) (m P) (k P)) (= (vs & V (v & Y & Y m) m) (v & V & Y (vs & V & Y m k)))))
(assert (forall ((& D) (V T) (m P) (k P) (e P)) (and (v & Y (v & Y & Y m) m) (= (v & V & Y m k) (v & V & Y (vs & V & Y m e) k)))))
(assert (forall ((& D) (s P) (a P) (a2 P)) (or (= a a2) (= (v & Y s a2) (v & N (vs & N s a2) a)))))
(declare-fun r (D T l) Bool)
(assert (forall ((D D) (s l)) (= (r D Y s) (li D Y (P s)))))
(declare-const D D)
(declare-const p l)
(declare-const o l)
(declare-const n Int)
(assert (and (li D Y (P p)) (l D N (P p) (P o) (I n))))
(assert (not (r D Y o)))
(check-sat)
