; COMMAND-LINE: --sat-solver=cadical --check-proofs --check-proofs-complete
; EXPECT: unsat
; Tests proof reconstruction of a datatypes tester merge conflict where the
; explanation lists the negated tester first, e.g. ~is-C(a) ^ is-C(b) ^ a=b.
; The positive tester must take the tester1 role so that DT_INST/CONTRA
; reconstruction applies, rather than falling back to a trust step.
(set-logic ALL)
(declare-sort SP 0)
(declare-fun I (Int) SP)
(declare-fun % (SP) Int)
(declare-sort ST 0)
(declare-const N ST)
(declare-sort SD 0)
(declare-const $ SD)
(declare-fun pr (SD ST) SD)
(declare-fun r_0 (SD ST) ST)
(declare-sort Sv 0)
(declare-sort Ss 0)
(declare-sort Svs 0)
(declare-datatypes ((Sl 0) (Su 0) (SBs 0) (Sib 0) (Sb 0) (Ssp 0) (Sm 0) (Sy 0) (SbBs 0) (Sk 0) (Spe 0) (Si 0) (Sp 0) (So 0) (SbB 0) (SBsp 0) (Se 0) (SbBsp 0) (SibB 0) (Sec 0) (Sspe 0) (SDot 0) (SBspe 0) (Sc 0) (Sf 0) (Sls 0) (St 0) (Sup 0) (Sn 0) (Spl 0) (Stu 0)) (((b!s (b!s Svs))) ((b!sp)) ((!s)) ((f)) ((ib!)) ((!s)) ((f)) ((b!s)) ((y)) ((y)) ((!spe)) ((spe)) ((ec)) ((!spe)) ((y)) ((b!sp)) ((f)) ((spe)) ((f)) ((b!sp)) ((c)) ((b!s)) ((b!s)) ((e) (pe (ec Svs)) (y (ib! Int))) ((ib)) ((y)) ((up)) ((pl)) ((y)) ((up)) ((y))))
(declare-fun l_0 (Sl) SP)
(declare-fun i (Sl) Sv)
(declare-fun li (Sl) Ss)
(declare-fun l_1 (Sc) Int)
(declare-const Y ST)
(declare-fun P (Sv) SP)
(declare-fun P (Ss) SP)
(declare-fun P (SP) Ss)
(declare-fun P (Sl) SP)
(declare-fun %P (SP) Sl)
(declare-fun y (Sc) SP)
(declare-fun Po (SP) Sc)
(assert (forall ((x SP)) (= x (P (P x)))))
(assert (forall ((x Sc)) (= x (Po (y x)))))
(declare-fun v_0 (SD ST SD ST SP) SP)
(declare-fun v_1 (SD ST SD ST SP SP) SP)
(declare-fun vs_0 (SD ST SD ST SP SP SP) SP)
(declare-fun vs_1 (SD ST SD ST SP SP) SP)
(declare-fun v_2 (SD ST SP SP) Bool)
(declare-fun vs_2 (SD ST SP SP) SP)
(declare-fun l_2 (SD ST SP SP SP) Bool)
(declare-fun li (SD ST SP) Bool)
(declare-fun l_3 (SD ST SP SP) Int)
(assert (or (forall ((D SD) (T ST) (s SP) (n SP)) (= (l_3 D T s n) (ite ((_ is e) (Po (v_1 $ T $ Y (P (li (%P s))) n))) (% (v_1 $ T $ T (P (i (%P s))) n)) (ite ((_ is pe) (Po (v_1 $ T $ Y (P (li (%P s))) n))) (% (v_1 $ T $ T (P (i (%P s))) n)) (l_1 (Po (y (Po (v_1 $ T $ Y (P (li (%P s))) n)))))))))))
(assert (or (forall ((D SD) (s SP)) (= (li D Y s) (forall ((d SP)) (= (I (l_3 D N s d)) (vs_1 D Y (pr D Y) (r_0 D Y) (l_0 (%P s)) d)))))))
(assert (or (forall ((D SD) (T ST) (p SP) (o SP) (n SP)) (= (l_2 D T p o n) (and (= (i (%P o)) (i (%P p))) (= (l_0 (%P o)) (l_0 (%P p))) (v_2 D Y o (P (i (%P p)))) ((_ is pe) (Po (v_1 $ T $ Y (P (li (%P p))) n))) (= (li (%P o)) (P (vs_0 $ T $ Y (P (P (vs_1 $ T $ Y (P (li (%P p))) p))) n (y e)))))))))
(assert (forall ((& SD) (V ST) (m SP) (k SP) (a SP)) (= a (v_1 & V & Y (vs_0 & V & Y m k a) k))))
(assert (forall ((& SD) (V ST) (m SP) (k SP) (e SP) (a SP)) (or (not (v_2 & V (v_0 & V & Y m) k)) (= (v_1 & V & Y m k) (v_1 & V & Y (vs_0 & V & Y m e a) k)))))
(assert (forall ((& SD) (V ST) (m SP) (k SP)) (= (vs_2 & V (v_0 & Y & Y m) m) (v_0 & V & Y (vs_1 & V & Y m k)))))
(assert (forall ((& SD) (V ST) (m SP) (k SP) (e SP)) (and (v_2 & Y (v_0 & Y & Y m) m) (= (v_1 & V & Y m k) (v_1 & V & Y (vs_1 & V & Y m e) k)))))
(assert (forall ((& SD) (s SP) (a SP) (a2 SP)) (or (= a a2) (= (v_2 & Y s a2) (v_2 & N (vs_2 & N s a2) a)))))
(declare-fun r_1 (SD ST Sl) Bool)
(assert (forall ((D SD) (s Sl)) (= (r_1 D Y s) (li D Y (P s)))))
(declare-const D SD)
(declare-const p Sl)
(declare-const o Sl)
(declare-const n Int)
(assert (and (li D Y (P p)) (l_2 D N (P p) (P o) (I n))))
(assert (not (r_1 D Y o)))
(check-sat)
