; EXPECT: feasible
; EXPECT: (
; EXPECT:   (define-fun f ((x Int)) Int (+ x (+ x x)))
; EXPECT: )
; COMMAND-LINE: --lang=sygus2 --sygus-out=status-and-def --no-check-synth-sol

; Variant of weight-simple.sy that uses a custom `:default` value for the
; weight keyword. Here every un-annotated rule contributes 0 to the total
; (same as the builtin default).

(set-logic NIA)
(set-feature :weights true)

(declare-weight w :default 0)

(synth-fun f ((x Int)) Int
  ((Start Int))
  ((Start Int (0 1 3 x
                (! (+ Start Start) :w 1)
                (! (* Start Start) :w 31))))
)

(declare-var x Int)

(constraint (= (f x) (* 3 x)))
(constraint (= (_ w f) 2))

(check-synth)
